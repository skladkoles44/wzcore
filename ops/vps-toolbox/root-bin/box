#!/usr/bin/env bash
set -euo pipefail

GREEN="\033[92m"
RESET="\033[0m"

DB="${DB:-/var/lib/max-bot1/bot.db}"
SVC="max-bot1.service"

case "${1:-}" in
  db)
    echo -e "${GREEN}===== BEGIN DB INVARIANTS =====${RESET}"
    sqlite3 "$DB" -cmd ".headers off" -cmd ".mode list"       "SELECT 'bad_out|'||COUNT(*) FROM messages WHERE direction='out' AND (msg_id IS NULL OR trim(msg_id)='');"       "SELECT 'out_total|'||COUNT(*) FROM messages WHERE direction='out';"
    echo -e "${GREEN}===== END DB INVARIANTS =====${RESET}"
    ;;

  fk)
    echo -e "${GREEN}===== BEGIN FK CHECK =====${RESET}"
    sqlite3 "$DB" "PRAGMA foreign_key_check;"
    echo -e "${GREEN}===== END FK CHECK =====${RESET}"
    ;;

  svc)
    echo -e "${GREEN}===== BEGIN SVC ${SVC} status =====${RESET}"
    systemctl is-active "$SVC" || true
    systemctl --no-pager --full status "$SVC" | sed -n "1,18p"
    echo -e "${GREEN}===== END SVC ${SVC} status =====${RESET}"
    ;;

  logs)
    echo -e "${GREEN}===== BEGIN LOGS ${SVC} =====${RESET}"
    journalctl -u "$SVC" -n 80 --no-pager || true
    echo -e "${GREEN}===== END LOGS ${SVC} =====${RESET}"
    ;;

  health)
    echo -e "${GREEN}===== BEGIN HEALTH =====${RESET}"
    curl -fsS http://127.0.0.1:8000/health || true
    echo
    echo -e "${GREEN}===== END HEALTH =====${RESET}"
    ;;

  *)
    echo "usage: box {db|fk|svc|logs|health}"
    exit 2
    ;;
esac
